{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/*"],
      "@shared/*": ["src/shared/*"],
      "@themes/*": ["src/themes/*"],
      "@ai/*": ["src/ai/*"],
      "@i18n/*": ["src/i18n/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
